---
// Top navigation bar. The only JS is a tiny theme toggle (vanilla, no framework
// runtime) to demonstrate dark mode - consistent with the zero-JS approach.
// Search renders the REAL site search component + engine (search.js), restyled
// via tokens in theme.css. The engine is unchanged; we only provide its markup.
import OctopusLogo from '../../../../public/docs/img/OctopusLogo.astro';
import Button from '../../core/Button.astro';
import Search from '../../../themes/octopus/components/Search.astro';
import { SITE } from '@config';

type Props = {
  lang?: string;
};
const { lang = SITE.default.lang } = Astro.props satisfies Props;
---

<header
  data-component="ink/docs/Header"
  class="sticky top-0 z-40 border-b border-border/70 bg-background/70 backdrop-blur-xl supports-[backdrop-filter]:bg-background/55"
>
  <!-- No left padding: the logo's left edge lines up with the sidebar column. -->
  <div class="mx-auto flex h-16 max-w-[1600px] items-center gap-4 pr-4 lg:pr-6">
    <!-- Left zone (flex-1): brand wordmark, left-aligned. The flex-1 sides keep
         the centre search column truly centered in the header. -->
    <div class="flex min-w-0 flex-1 items-center">
      <a
        href="/docs"
        class="group mvp-brand flex shrink-0 items-center gap-2.5 rounded-md outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background"
        style="--octopus-logo-text-color: var(--foreground);"
      >
        <OctopusLogo />
        <span
          class="hidden border-l border-border pl-2.5 text-sm font-medium text-muted-foreground sm:inline-block"
          >Docs</span
        >
      </a>
    </div>

    <!-- Centre zone: the REAL site search (markup + search.js engine), restyled
         in theme.css under `.ds-search`. Width/expand-on-focus handled there. -->
    <div class="ds-search relative hidden md:flex">
      <Search lang={lang} />
    </div>

    <nav class="flex min-w-0 flex-1 items-center justify-end gap-1">
      <a
        href="https://octopus.com"
        class="hidden h-9 items-center rounded-md px-3 text-base text-muted-foreground transition-colors hover:bg-muted hover:text-foreground sm:inline-flex"
        >octopus.com</a
      >
      <span class="mx-1 hidden h-5 w-px bg-border sm:block" aria-hidden="true"
      ></span>
      <button
        id="mvp-theme-toggle"
        type="button"
        aria-label="Toggle dark mode"
        class="grid h-9 w-9 place-items-center rounded-md border border-border text-muted-foreground outline-none transition-colors hover:bg-muted hover:text-foreground focus-visible:ring-2 focus-visible:ring-ring"
      >
        <svg
          class="block dark:hidden"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><circle cx="12" cy="12" r="4"></circle><path
            d="M12 2v2m0 16v2M4.93 4.93l1.41 1.41m11.32 11.32 1.41 1.41M2 12h2m16 0h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"
          ></path></svg
        >
        <svg
          class="hidden dark:block"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path></svg
        >
      </button>
      <Button
        href="https://octopus.com/start"
        variant="primary"
        class="ml-1.5 hidden h-9 gap-1.5 px-4 py-0 sm:inline-flex"
      >
        Start free trial
        <svg
          class="h-3.5 w-3.5"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"></path></svg
        >
      </Button>
    </nav>
  </div>
  <!-- Bottom hairline. -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-primary/45 to-transparent"
  >
  </div>
</header>

<style is:global>
  .mvp-brand .octo-header__logo {
    height: 3.125rem;
    width: auto;
    display: block;
    transition: opacity 0.2s ease;
  }
  .mvp-brand:hover .octo-header__logo {
    opacity: 0.88;
  }
</style>

<script is:inline>
  (() => {
    const root = document.documentElement;
    const stored = localStorage.getItem('mvp-theme');
    if (stored === 'dark') root.setAttribute('data-theme', 'dark');
    document
      .getElementById('mvp-theme-toggle')
      ?.addEventListener('click', () => {
        const dark = root.getAttribute('data-theme') === 'dark';
        if (dark) {
          root.removeAttribute('data-theme');
          localStorage.setItem('mvp-theme', 'light');
        } else {
          root.setAttribute('data-theme', 'dark');
          localStorage.setItem('mvp-theme', 'dark');
        }
      });
  })();
</script>

<script is:inline>
  // Scroll shades on the search results dropdown (mirrors the sidebar).
  (() => {
    const res = document.querySelector('.ds-search [data-site-search-results]');
    if (!res) return;
    const update = () => {
      res.setAttribute('data-at-top', res.scrollTop <= 1 ? 'true' : 'false');
      res.setAttribute(
        'data-at-bottom',
        res.scrollTop + res.clientHeight >= res.scrollHeight - 1
          ? 'true'
          : 'false'
      );
    };
    res.addEventListener('scroll', update, { passive: true });
    new MutationObserver(update).observe(res, { childList: true });
    update();
  })();
</script>
