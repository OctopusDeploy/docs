---
type Intent = 'info' | 'success' | 'warning' | 'problem';

interface Props {
  intent?: Intent;
  title?: string;
}

const { intent = 'info', title } = Astro.props;

// Colors pull from the intent tokens defined in tokens.css.
const styles: Record<Intent, string> = {
  info: '[--c:var(--info)] [--bg:var(--info-bg)] [--bd:var(--info-border)]',
  success:
    '[--c:var(--success)] [--bg:var(--success-bg)] [--bd:var(--success-border)]',
  warning:
    '[--c:var(--warning)] [--bg:var(--warning-bg)] [--bd:var(--warning-border)]',
  problem:
    '[--c:var(--problem)] [--bg:var(--problem-bg)] [--bd:var(--problem-border)]',
};

const labels: Record<Intent, string> = {
  info: 'Note',
  success: 'Success',
  warning: 'Warning',
  problem: 'Important',
};

// Per-intent inline SVG paths (24x24 viewBox), stroke-based to match the brand iconography.
const icons: Record<Intent, string> = {
  info: '<circle cx="12" cy="12" r="9"></circle><path d="M12 11v5"></path><path d="M12 8h.01"></path>',
  success:
    '<circle cx="12" cy="12" r="9"></circle><path d="m8.5 12.5 2.5 2.5 4.5-5"></path>',
  warning:
    '<path d="M10.3 4.3 2.5 18a2 2 0 0 0 1.7 3h15.6a2 2 0 0 0 1.7-3L13.7 4.3a2 2 0 0 0-3.4 0Z"></path><path d="M12 9v4"></path><path d="M12 17h.01"></path>',
  problem:
    '<circle cx="12" cy="12" r="9"></circle><path d="M12 8v5"></path><path d="M12 16h.01"></path>',
};
---

<div
  data-component="ink/core/Callout"
  class={`my-7 flex gap-3.5 rounded-xl border border-l-[3px] px-4 py-4 text-[0.95rem] shadow-[var(--shadow-sm)] ${styles[intent]}`}
  style="border-color: color-mix(in oklab, var(--bd) 32%, transparent); border-left-color: var(--bd); background: var(--bg); color: var(--c);"
  role="note"
>
  <span
    class="mt-0.5 grid h-7 w-7 shrink-0 place-items-center rounded-lg"
    style="color: var(--bd); background: color-mix(in oklab, var(--bd) 15%, transparent); box-shadow: 0 0 16px -3px color-mix(in oklab, var(--bd) 55%, transparent);"
  >
    <svg
      class="h-[17px] w-[17px]"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
      set:html={icons[intent]}
    />
  </span>
  <div class="min-w-0">
    <p class="mb-1 font-semibold leading-snug">{title ?? labels[intent]}</p>
    <div
      class="leading-relaxed opacity-95 [&_a]:font-medium [&_a]:underline [&_a]:underline-offset-2 [&_p]:my-1 [&_p:last-child]:mb-0"
    >
      <slot />
    </div>
  </div>
</div>
