---
interface Crumb {
  label: string;
  href?: string;
}
interface Props {
  items: Crumb[];
}
const { items } = Astro.props;
---

<!-- RDFa BreadcrumbList preserved (SEO guardrail: matches existing Breadcrumbs.astro) -->
<nav
  aria-label="Breadcrumb"
  class="mb-4 text-xs"
  data-component="ink/docs/Breadcrumbs"
>
  <ol
    class="flex flex-wrap items-center gap-1.5 text-muted-foreground"
    vocab="https://schema.org/"
    typeof="BreadcrumbList"
  >
    {
      items.map((c, i) => (
        <li
          class="flex items-center gap-1.5"
          property="itemListElement"
          typeof="ListItem"
        >
          {c.href ? (
            <a
              property="item"
              typeof="WebPage"
              href={c.href}
              class="hover:text-foreground transition-colors"
            >
              <span property="name">{c.label}</span>
            </a>
          ) : (
            <span property="name" class="text-foreground">
              {c.label}
            </span>
          )}
          <meta property="position" content={String(i + 1)} />
          {i < items.length - 1 && (
            <span aria-hidden="true" class="text-border">
              /
            </span>
          )}
        </li>
      ))
    }
  </ol>
</nav>
