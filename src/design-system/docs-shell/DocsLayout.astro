---
import '../theme.css';
import DocsHeader from './DocsHeader.astro';
import DocsSidebar from './DocsSidebar.astro';
import DocsToc from './DocsToc.astro';
import DocsBreadcrumbs from './DocsBreadcrumbs.astro';
import Footer from '../../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  breadcrumbs: { label: string; href?: string }[];
  sidebar: { title: string; items: { label: string; href: string; active?: boolean }[] }[];
  toc: { label: string; href: string; depth?: number }[];
}

const { title, description, breadcrumbs, sidebar, toc } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · Octopus Docs</title>
    {description && <meta name="description" content={description} />}
    <!-- Shared footer styles (footer remains the existing shared component) -->
    <link rel="stylesheet" href="/docs/css/footer-bundle.css" />
    <!-- Avoid dark-mode flash before the toggle script runs -->
    <script is:inline>
      if (localStorage.getItem('mvp-theme') === 'dark')
        document.documentElement.setAttribute('data-theme', 'dark');
    </script>
  </head>
  <body class="min-h-screen bg-background font-sans text-foreground antialiased">
    <DocsHeader />

    <div class="mx-auto flex max-w-[1600px]">
      <DocsSidebar sections={sidebar} />

      <div class="flex min-w-0 flex-1">
        <main class="min-w-0 flex-1 px-5 py-6 sm:px-6 lg:px-12 lg:py-14">
          <div class="mx-auto max-w-3xl xl:mx-0">
            <details class="group mb-5 rounded-lg border border-border bg-sidebar lg:hidden">
              <summary
                class="flex cursor-pointer list-none items-center justify-between gap-2 px-4 py-2.5 text-sm font-medium text-foreground [&::-webkit-details-marker]:hidden"
              >
                <span class="flex items-center gap-2">
                  <svg class="h-4 w-4 text-muted-foreground" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 6h16M4 12h16M4 18h16"></path></svg>
                  Documentation menu
                </span>
                <svg class="h-4 w-4 text-muted-foreground transition-transform group-open:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"></path></svg>
              </summary>
              <nav class="border-t border-border px-3 py-3" aria-label="Documentation navigation">
                {sidebar.map((section) => (
                  <div class="mb-3 last:mb-0">
                    <p class="mb-1 px-2 text-[0.72rem] font-semibold uppercase tracking-[0.08em] text-muted-foreground/70">
                      {section.title}
                    </p>
                    <ul class="space-y-px">
                      {section.items.map((item) => (
                        <li>
                          <a
                            href={item.href}
                            aria-current={item.active ? 'page' : undefined}
                            class={`block rounded-md px-2 py-1.5 text-[0.925rem] transition-colors ${
                              item.active
                                ? 'bg-primary/10 font-medium text-primary'
                                : 'text-sidebar-foreground hover:bg-muted hover:text-foreground'
                            }`}
                          >
                            {item.label}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                ))}
              </nav>
            </details>

            <DocsBreadcrumbs items={breadcrumbs} />

            <article itemscope itemtype="https://schema.org/TechArticle">
              <header class="mb-8 border-b border-border pb-7">
                <h1
                  class="text-[2.05rem] font-bold leading-[1.15] tracking-[-0.02em] text-foreground"
                  itemprop="headline"
                >
                  {title}
                </h1>
                {description && (
                  <p
                    class="mt-3 text-lg leading-relaxed text-muted-foreground"
                    itemprop="description"
                  >
                    {description}
                  </p>
                )}
              </header>

              <div class="prose" itemprop="articleBody">
                <slot />
              </div>
            </article>
          </div>
        </main>

        <DocsToc items={toc} />
      </div>
    </div>

    <Footer />
  </body>
</html>
