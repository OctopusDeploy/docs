---
import SidebarBehavior from './SidebarBehavior.astro';
interface NavItem {
  label: string;
  href: string;
  active?: boolean;
}
interface NavSection {
  title: string;
  items: NavItem[];
}
interface Props {
  sections: NavSection[];
}
const { sections } = Astro.props;
---

<aside
  class="hidden w-[18.75rem] shrink-0 border-r border-border/60 bg-sidebar/55 backdrop-blur-sm lg:block"
>
  <div
    class="ds-navscroll"
    data-navscroll
    data-at-top="true"
    data-at-bottom="true"
  >
    <nav
      class="ds-navscroll__viewport px-3.5 py-8"
      data-navscroll-viewport
      aria-label="Documentation navigation"
    >
      {
        sections.map((section, si) => (
          <div class={si === sections.length - 1 ? '' : 'mb-7'}>
            <p class="mb-2.5 px-[0.65rem] text-xs font-semibold uppercase tracking-[0.14em] text-muted-foreground/70">
              {section.title}
            </p>
            <ul class="space-y-px">
              {section.items.map((item) => (
                <li>
                  <a
                    href={item.href}
                    aria-current={item.active ? 'page' : undefined}
                    class={`group relative flex items-center rounded-lg px-[0.6rem] py-[0.4rem] text-base leading-snug outline-none transition-[color,background-color] duration-150 focus-visible:ring-2 focus-visible:ring-ring ${
                      item.active
                        ? 'bg-primary/[0.09] font-semibold text-primary'
                        : 'font-normal text-sidebar-foreground hover:bg-muted/55 hover:text-foreground'
                    }`}
                  >
                    {item.active && (
                      <span
                        aria-hidden="true"
                        class="absolute inset-y-[0.32rem] left-0 w-[3px] rounded-r-full bg-primary shadow-[0_0_10px_1px_var(--glow-primary)]"
                      />
                    )}
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </nav>
    <span class="ds-navscroll__fade ds-navscroll__fade--top" aria-hidden="true"
    ></span>
    <span
      class="ds-navscroll__fade ds-navscroll__fade--bottom"
      aria-hidden="true"></span>
  </div>
  <SidebarBehavior />
</aside>
