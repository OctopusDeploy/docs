---
interface NavItem {
  label: string;
  href: string;
  active?: boolean;
}
interface NavSection {
  title: string;
  items: NavItem[];
}
interface Props {
  sections: NavSection[];
}
const { sections } = Astro.props;
---

<aside
  class="hidden w-[16.5rem] shrink-0 border-r border-border/60 bg-sidebar/55 backdrop-blur-sm lg:block"
  aria-label="Documentation navigation"
>
  <nav
    class="sticky top-16 max-h-[calc(100vh-4rem)] overflow-y-auto px-3.5 py-8 [scrollbar-gutter:stable]"
  >
    {
      sections.map((section, si) => (
        <div class={si === sections.length - 1 ? '' : 'mb-7'}>
          <p class="mb-2.5 px-3 text-[0.7rem] font-semibold uppercase tracking-[0.14em] text-muted-foreground/60">
            {section.title}
          </p>
          <ul class="space-y-0.5">
            {section.items.map((item) => (
              <li>
                <a
                  href={item.href}
                  aria-current={item.active ? 'page' : undefined}
                  class={`group relative flex items-center rounded-lg px-3 py-[0.47rem] text-[0.9rem] leading-snug outline-none transition-[color,background-color] duration-150 focus-visible:ring-2 focus-visible:ring-ring ${
                    item.active
                      ? 'bg-primary/[0.08] font-semibold text-primary'
                      : 'font-medium text-sidebar-foreground hover:bg-muted/55 hover:text-foreground'
                  }`}
                >
                  {item.active && (
                    <span
                      aria-hidden="true"
                      class="absolute inset-y-1.5 left-0 w-[3px] rounded-r-full bg-primary shadow-[0_0_10px_1px_var(--glow-primary)]"
                    />
                  )}
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </nav>
</aside>
