---
interface NavItem {
  label: string;
  href: string;
  active?: boolean;
}
interface NavSection {
  title: string;
  items: NavItem[];
}
interface Props {
  sections: NavSection[];
}
const { sections } = Astro.props;
---

<aside
  class="hidden lg:block w-64 shrink-0 border-r border-border bg-sidebar"
  aria-label="Documentation navigation"
>
  <nav
    class="sticky top-16 max-h-[calc(100vh-4rem)] overflow-y-auto px-3 py-6 [scrollbar-width:thin]"
  >
    {
      sections.map((section, si) => (
        <div class={si === sections.length - 1 ? '' : 'mb-5'}>
          <p class="mb-1.5 px-2.5 text-[0.72rem] font-semibold uppercase tracking-[0.09em] text-muted-foreground/65">
            {section.title}
          </p>
          <ul>
            {section.items.map((item) => (
              <li>
                <a
                  href={item.href}
                  aria-current={item.active ? 'page' : undefined}
                  class={`relative block rounded-md py-[0.35rem] pl-2.5 pr-2 text-[0.925rem] leading-snug outline-none transition-colors duration-150 focus-visible:ring-2 focus-visible:ring-ring ${
                    item.active
                      ? 'bg-primary/[0.09] font-medium text-primary before:absolute before:inset-y-[0.35rem] before:-left-3 before:w-[2px] before:rounded-r-full before:bg-primary'
                      : 'text-sidebar-foreground hover:bg-muted/70 hover:text-foreground'
                  }`}
                >
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </nav>
</aside>
