---
// Recursive nav renderer for the real Octopus nav tree (NavPage[]).
// Reuses DocsSidebar's visual language (eyebrow section labels, active-item
// indicator, focus rings) but renders nested native <details> sections.
// Zero-JS: collapsible state is native <details open>.
import { Accelerator } from 'astro-accelerator-utils';
import type { NavPage } from 'astro-accelerator-utils/types/NavPage';
import { SITE } from '@config';

const accelerator = new Accelerator(SITE);

type Props = {
  page: NavPage;
  depth?: number;
};
const { page, depth = 0 } = Astro.props satisfies Props;

const displayLink = page.title != null;
const linkTitle = page.title === page.fullTitle ? null : page.fullTitle;
const children = page.children.slice().sort((a, b) => a.order - b.order);
---

{
  displayLink && page.children.length === 0 && (
    <li data-component="DocsSidebarNav">
      <a
        href={accelerator.urlFormatter.formatAddress(page.url)}
        aria-current={page.ariaCurrent ? page.ariaCurrent : undefined}
        rel={page.rel}
        title={linkTitle}
        class={`group/link relative flex items-center justify-between gap-2 rounded-lg py-[0.47rem] pr-2.5 text-[0.9rem] leading-snug outline-none transition-[color,background-color] duration-150 focus-visible:ring-2 focus-visible:ring-ring ${
          depth > 0 ? 'pl-3' : 'pl-3'
        } ${
          page.ariaCurrent
            ? 'bg-primary/[0.08] font-semibold text-primary before:absolute before:inset-y-1.5 before:left-0 before:w-[3px] before:rounded-r-full before:bg-primary before:shadow-[0_0_10px_1px_var(--glow-primary)]'
            : 'font-medium text-sidebar-foreground hover:bg-muted/55 hover:text-foreground'
        }`}
      >
        <span class="truncate">{page.title}</span>
        {depth === 0 && (
          <svg
            class="h-3.5 w-3.5 shrink-0 text-muted-foreground/45"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="m9 18 6-6-6-6" />
          </svg>
        )}
      </a>
    </li>
  )
}
{
  displayLink && page.children.length > 0 && (
    <li data-component="DocsSidebarNav">
      <details
        open={page.isOpen}
        class={`group ${depth === 0 ? 'mb-7 last:mb-0' : 'mt-px'}`}
      >
        <summary
          class={`flex cursor-pointer list-none items-center justify-between gap-2 rounded-lg outline-none focus-visible:ring-2 focus-visible:ring-ring [&::-webkit-details-marker]:hidden ${
            depth === 0
              ? 'mb-2.5 px-3 py-1 text-[0.7rem] font-semibold uppercase tracking-[0.14em] text-muted-foreground/60'
              : 'px-3 py-[0.47rem] text-[0.9rem] font-medium leading-snug text-sidebar-foreground hover:bg-muted/55 hover:text-foreground'
          }`}
        >
          <span>{page.section}</span>
          <svg
            class="h-3.5 w-3.5 shrink-0 text-muted-foreground/70 transition-transform group-open:rotate-90"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="m9 18 6-6-6-6" />
          </svg>
        </summary>
        <ul
          class={
            depth === 0
              ? 'space-y-0.5'
              : 'ml-3 space-y-0.5 border-l border-border/50 pl-2'
          }
        >
          {children.map((child) => (
            <Astro.self page={child} depth={depth + 1} />
          ))}
        </ul>
      </details>
    </li>
  )
}
